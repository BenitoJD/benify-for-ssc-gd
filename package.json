{
  "name": "olli-academy-ssc-gd",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace olli-academy-ssc-gd-web",
    "dev:api": "cd apps/api && uvicorn internal.main:app --reload --host 0.0.0.0 --port 3100",
    "dev:infra": "docker compose up -d",
    "dev:infra:down": "docker compose down",
    "build:web": "npm run build --workspace olli-academy-ssc-gd-web",
    "test:api": "cd apps/api && python3 -m pytest tests -q --disable-warnings -p no:warnings -o asyncio_default_fixture_loop_scope=function",
    "test:web": "npm run test --workspace olli-academy-ssc-gd-web",
    "lint:web": "npm run lint --workspace olli-academy-ssc-gd-web",
    "dev": "docker compose up -d"
  }
}
