[Unit]
Description=Benify for SSC GD auto deployment
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=oneshot
Environment=REPO_DIR=/opt/benify-for-ssc-gd
Environment=BRANCH=main
Environment=ENV_FILE=/opt/benify-for-ssc-gd/.env.production
Environment=COMPOSE_FILE=/opt/benify-for-ssc-gd/docker-compose.prod.yml
ExecStart=/opt/benify-for-ssc-gd/ops/deploy/auto-deploy.sh
