# Application
APP_NAME=Benify API
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=3100

# Database
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Replace all values below with your actual database credentials
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=benify
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
REDIS_CACHE_TTL=300

# MinIO/S3
MINIO_ENDPOINT=localhost:3102
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=benify
MINIO_SECURE=false

# JWT (IMPORTANT: Change this in production!)
JWT_SECRET_KEY=your_super_secret_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3101","http://localhost:3000"]

# OAuth (Optional - for Google Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (for callbacks)
APP_ORIGIN=http://localhost:3101
