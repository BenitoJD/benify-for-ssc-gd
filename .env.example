# ================================
# Benify Production Environment
# ================================

# ================
# Application
# ================
DEBUG=false
LOG_LEVEL=INFO

# ================
# Database (PostgreSQL)
# ================
DB_USER=postgres
DB_PASSWORD=your-secure-db-password-change-in-production
DB_NAME=benify

# ================
# Redis
# ================
# No password for local dev, set REDIS_PASSWORD for production
REDIS_PASSWORD=

# ================
# MinIO (S3-compatible Storage)
# ================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-secure-minio-password-change-in-production

# ================
# JWT Authentication
# ================
# REQUIRED: Generate a secure random string (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars

# ================
# API URLs (for frontend)
# ================
NEXT_PUBLIC_API_URL=http://nginx/api
NEXT_PUBLIC_APP_URL=http://localhost:3100

# ================
# Google OAuth (if using)
# ================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================
# FCM Push Notifications (if using)
# ================
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_PRIVATE_KEY_ID=your-private-key-id
# FCM_PRIVATE_KEY=your-private-key
# FCM_CLIENT_EMAIL=your-client-email
# FCM_CLIENT_ID=your-client-id
